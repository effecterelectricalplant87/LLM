{
  "AppConfig": {

    // ── Runtime / execution settings ──────────────────────────────────────────

    // Action to perform: "Train" or "Prompt".
    "Action":    "Train",

    // Target vocabulary size for the tokenizer.
    // Larger values capture more meaningful subwords but increase model size.
    // Recommended range: 2000–8000 for a corpus of ~5M characters.
    "VocabSize": 4000,

    // Validation split strategy: "None", "Tail", or "Random".
    //   None   – no validation, train on all tokens.
    //   Tail   – hold out the last ValidationFraction of the corpus.
    //   Random – randomly assign ValidationFraction of chunks to validation.
    "ValidationSplit":    "Tail",

    // Fraction of tokens to hold out for validation (0.1 = 10%).
    "ValidationFraction": 0.1,

    // Training stop mode:
    //   Epochs        – train for exactly Epochs epochs, no early stopping.
    //   Patience      – train up to Epochs max, stop if val_loss doesn't improve
    //                   for Patience consecutive epochs.
    //   EarlyStopping – train up to Epochs max, stop when val_loss improvement
    //                   falls below MinDeltaLoss. Requires a validation split.
    "TrainingMode": "EarlyStopping",

    // Maximum consecutive epochs without sufficient val_loss improvement
    // before stopping. Used by Patience and EarlyStopping modes.
    "Patience": 5,

    // Minimum improvement in val_loss that resets the patience counter.
    // Used by EarlyStopping mode.
    "MinDeltaLoss": 0.001,

    // Backend to use for computation. "GPU" requires CUDA; fall back to "CPU".
    "Backend":   "GPU",

    // Corpus file to train on.
    "TrainFile": "/mnt/d/src/LLM/LLM_Documentation/sample_corpus_large.txt",

    // File to save model weights to after training.
    "SaveFile":  "weights.bin",

    // File to load model weights from before training or inference. Empty = start fresh.
    "LoadFile":  "",

    // Redirect stderr to this file. Empty = stderr goes to the console.
    "ErrorFile": "error.txt",

    // Save a crash-recovery checkpoint every this many minutes of wall-clock training time.
    // 0 = only save at the end of each epoch.
    "CheckpointEveryMinutes": 60,

    // Maximum tokens to generate per response.
    "MaxTokens":   200,

    // Context compaction strategy when context window is full:
    //   FIFO          – drop oldest tokens first.
    //   SlidingWindow – preserve the first AnchorFraction of the context (initial
    //                   framing / system prompt), FIFO the rest.
    "ContextCompaction": "FIFO",

    // Fraction of ContextLength to anchor at the start for SlidingWindow (e.g. 0.2 = 20%).
    "AnchorFraction": 0.2,

    // Sampling temperature (1.0 = unmodified, lower = more deterministic).
    "Temperature": 0.8,

    // Top-K sampling filter (0 = disabled).
    "TopK":        15
  },

  "TransformerConfig": {

    // ── Model architecture ────────────────────────────────────────────────────

    // Width of the residual stream (d_model). Every token is represented as a
    // vector of this size throughout the network.
    // Typical values: 64 (tiny), 128 (small), 256 (medium), 768 (GPT-2 base).
    "EmbeddingDim": 768,

    // Number of attention heads.
    // MUST divide EmbeddingDim exactly  →  d_head = EmbeddingDim / NumHeads.
    // Valid head counts for common embedding sizes:
    //   EmbeddingDim=64  → 1, 2, 4, 8, 16, 32, 64
    //   EmbeddingDim=128 → 1, 2, 4, 8, 16, 32, 64, 128
    //   EmbeddingDim=256 → 1, 2, 4, 8, 16, 32, 64, 128, 256
    // Rule of thumb: d_head = 32 or 64 works well
    //   (e.g. EmbeddingDim=128, NumHeads=4 → d_head=32).
    "NumHeads": 16,

    // Number of stacked transformer blocks (depth of the network).
    // More layers = more abstract reasoning, at higher compute cost.
    // Typical values: 2 (tiny), 4 (small), 6–12 (medium), 96 (GPT-3).
    "NumLayers": 8,

    // Hidden size of the feed-forward network inside each block.
    // Convention: 4 × EmbeddingDim  (e.g. EmbeddingDim=128 → FFNDim=512).
    "FFNDim": 3072,

    // Maximum sequence length (context window).
    // Attention cost scales as O(T²), so longer contexts are slower.
    // Typical values: 128, 256, 512, 1024, 2048.
    "ContextLength": 128,

    // ── Reproducibility ──────────────────────────────────────────────────────

    // Seed for weight initialisation. Use a fixed value (e.g. 42) for
    // reproducible runs. Set to -1 to use a random seed each run.
    "Seed": 42,

    // ── Training ─────────────────────────────────────────────────────────────

    // Number of full passes over the training data.
    // More epochs improves convergence but risks overfitting on small corpora.
    // On a large corpus (>1M tokens) even 1–5 epochs can be meaningful.
    "Epochs": 25,

    // Number of forward/backward passes before one Adam update.
    // Effective batch = AccumulationSteps × ContextLength tokens.
    // Higher values give smoother gradients at the cost of more compute per update.
    // Default 1 = standard single-step update.
    "AccumulationSteps": 1,

    // ── Sampling ─────────────────────────────────────────────────────────────

    // Print a generated text sample every N epochs. Set to 0 to disable.
    "SampleEvery": 5,

    // Prompt used for the training sample. Change this to match your corpus.
    "SamplePrompt": "Shall ",

    // ── Adam optimiser ────────────────────────────────────────────────────────

    // Adam step size — the PEAK learning rate reached after warmup.
    // 3e-4 is a reliable default for small models.
    // Reduce to 1e-4 or 5e-5 for larger models or when loss is unstable.
    "LearningRate": 3e-4,

    // Number of Adam steps over which LR ramps linearly from 0 → LearningRate.
    // 0 = no warmup (start at peak LR immediately).
    "WarmupSteps": 200,

    // Minimum LR at the end of the cosine decay (floor).
    // Typically ~3–10 % of LearningRate.
    "MinLearningRate": 1e-5,

    // Use Rotary Positional Encoding (RoPE) instead of sinusoidal additive PE.
    // RoPE gives better relative-position sensitivity and length generalisation.
    // Requires HeadDim (EmbeddingDim / NumHeads) to be even (true for all standard configs).
    "UseRoPE": true,

    // Gradient momentum decay (first moment). Standard value: 0.9.
    "Beta1": 0.9,

    // Squared-gradient decay (second moment). Standard value: 0.999.
    // Use 0.95 if you see sluggish early training.
    "Beta2": 0.999,

    // Denominator epsilon to prevent division by zero. Standard value: 1e-8.
    "AdamEps": 1e-8,

    // ── Gradient clipping ─────────────────────────────────────────────────────

    // Maximum global L2 norm of all gradients before rescaling.
    // 1.0 is standard. Raise to 5.0 if training stalls early;
    // lower to 0.5 if loss spikes.
    "GradClip": 1.0
  }
}
